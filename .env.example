# ---- Core ----
APP_NAME="SQL Database Agent"
APP_ENV=local               # local | staging | production
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO              # DEBUG | INFO | WARNING | ERROR

# ---- Database (read/write role for migrations only) ----
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/sales_db

# Application uses this READ-ONLY DSN at runtime
READONLY_DATABASE_URL=postgresql+psycopg://readonly_user:readonly_pass@localhost:5432/sales_db

# ---- LLM ----
LLM_PROVIDER=openai         # openai | azure_openai | anthropic
OPENAI_API_KEY=sk-replace-me
OPENAI_MODEL=gpt-4o
OPENAI_TEMPERATURE=0
OPENAI_REQUEST_TIMEOUT=60

# Azure OpenAI (alternative provider)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# Anthropic (alternative provider)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# ---- Security / Guardrails ----
SQL_QUERY_TIMEOUT_SECONDS=15
SQL_MAX_ROWS=200
SQL_FORBIDDEN_KEYWORDS=DROP,TRUNCATE,DELETE,UPDATE,INSERT,ALTER,GRANT,REVOKE,COPY,VACUUM,CREATE
ALLOW_DDL=false

# ---- CORS ----
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ---- Observability: LangSmith ----
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=lsv2_pt_replaceme
LANGSMITH_PROJECT=sql-agent-prod

# ---- Redis (optional, for rate limiting & cache) ----
REDIS_URL=redis://localhost:6379/0
RATE_LIMIT_PER_MINUTE=30

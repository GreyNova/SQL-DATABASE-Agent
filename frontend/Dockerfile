# ---- Build stage ----
FROM node:20-alpine AS build
WORKDIR /app

COPY package.json ./
RUN npm install

COPY . .
RUN npm run build

# ---- Serve stage (static SPA + reverse proxy to backend) ----
FROM nginx:1.27-alpine AS serve
# The nginx config lives at repo root in nginx/; the build context is repo root
# (see docker-compose `context: .`), so we reference it by its full path.
COPY nginx/frontend.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist /usr/share/nginx/html
EXPOSE 80
HEALTHCHECK --interval=30s --timeout=3s CMD wget -qO- http://localhost/ || exit 1
CMD ["nginx", "-g", "daemon off;"]
